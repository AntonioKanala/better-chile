# Better Chile - Environment Configuration
# SECURITY: This is a TEMPLATE ONLY. Never commit actual values to Git.
# Copy this file to .env and fill in real values locally.

# Supabase Configuration
# Get these from: https://app.supabase.com → Settings → API Keys
SUPABASE_URL=https://mconaxbaemtkhjjgxcrb.supabase.co
SUPABASE_KEY=your_service_role_key_here_keep_secret

# OpenAI Configuration
# Get this from: https://platform.openai.com/account/api-keys
# WARNING: This key has billing access. Protect it carefully.
OPENAI_API_KEY=sk-your_api_key_here_keep_secret

# Optional: Rate limiting (requests per minute)
OPENAI_RATE_LIMIT=60

# Optional: Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
